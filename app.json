{
  "expo": {
    "name": "Lzy Learn Korean",
    "slug": "korean-app",
    "version": "1.5.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "scheme": "lzy-learn-korean",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "backgroundColor": "#0f172a",
      "splash": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#0f172a"
      },
      "supportsTablet": false,
      "buildNumber": "23",
      "bundleIdentifier": "com.hanflow.korean",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lzy Learn Korean needs microphone access so you can practice speaking Korean and get pronunciation feedback.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hanflow.korean",
      "permissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#1A0A2E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://hanflow-tts-proxy.vercel.app",
      "eas": {
        "projectId": "d223b85b-3dd0-4e2f-b1be-995d96287446"
      }
    }
  }
}
