{
  "name": "NitroIap",
  "version": "14.7.20",
  "summary": "React Native In-App Purchases module for iOS and Android using Nitro",
  "homepage": "https://github.com/hyochan/react-native-iap",
  "license": "MIT",
  "authors": "hyochan <hyo@hyo.dev> (https://github.com/hyochan)",
  "platforms": {
    "ios": "15.0",
    "tvos": "16.0",
    "osx": "14.0",
    "watchos": "8.0",
    "visionos": "1.0"
  },
  "source": {
    "git": "https://github.com/hyochan/react-native-iap.git",
    "tag": "14.7.20"
  },
  "source_files": [
    "ios/**/*.{swift}",
    "ios/**/*.{m,mm}",
    "nitrogen/generated/shared/**/*.{h,hpp,c,cpp,swift}",
    "nitrogen/generated/ios/**/*.{h,hpp,c,cpp,mm,swift}"
  ],
  "exclude_files": [
    "ios/RnIap-Bridging-Header.h"
  ],
  "dependencies": {
    "NitroModules": [],
    "React-Core": [],
    "React-jsi": [],
    "React-callinvoker": [],
    "openiap": [
      "1.3.15"
    ],
    "React-RCTFabric": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "React-renderercss": [],
    "hermes-engine": [],
    "ReactNativeDependencies": [],
    "React-Core-prebuilt": []
  },
  "public_header_files": [
    "nitrogen/generated/shared/**/*.{h,hpp}",
    "nitrogen/generated/ios/NitroIap-Swift-Cxx-Bridge.hpp"
  ],
  "private_header_files": [
    "nitrogen/generated/ios/c++/**/*.{h,hpp}",
    "nitrogen/generated/shared/**/views/**/*"
  ],
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "SWIFT_OBJC_INTEROP_MODE": "objcxx",
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED=1 ",
    "OTHER_SWIFT_FLAGS": "$(inherited) -DRCT_NEW_ARCH_ENABLED"
  },
  "compiler_flags": "-DRCT_NEW_ARCH_ENABLED=1"
}
